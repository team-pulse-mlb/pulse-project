# 외부 API
BDL_API_KEY=
# ai-service가 OpenAI 호출에 사용한다(비우면 문구 생성만 실패, 앱 기동은 됨).
# Docker Compose가 저장소 루트의 .env에서 읽어 ai-service에 주입한다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# S3 라이브 raw archive 리플레이
PULSE_REPLAY_S3_BUCKET=
PULSE_REPLAY_MAX_OBJECTS_PER_PREFIX=200
AWS_REGION=ap-northeast-2

# 로컬 경기 시뮬레이션
# application.yml의 pulse.simulation.games에 정의된 경기를 사용한다.
PULSE_SIMULATION_SPEED=20
PULSE_SIMULATION_PRESET=SURGE

# PostgreSQL
# POSTGRES_PASSWORD는 로컬에서 사용할 비밀번호로 설정한다.
# 팀원마다 다르게 정해도 되지만 DBeaver와 Spring Boot도 같은 값을 사용해야 한다.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse

# Redis
# 로컬 개발 Redis는 비밀번호 없이 사용한다.
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
# RABBITMQ_PASSWORD는 로컬에서 사용할 비밀번호로 설정한다.
# 비어 있으면 로컬 Compose 기동이 실패한다.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=pulse
RABBITMQ_PASSWORD=pulse

# 인증
# JWT_SECRET에는 로그인 토큰이 아니라 JWT 서명에 사용할 서버 비밀키를 넣는다.
# 저장소 루트의 Git Bash에서 다음 명령으로 생성할 수 있다.
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# 출력된 값을 JWT_SECRET= 뒤에 붙인다. 이 값은 로컬 전용이며 저장소에 커밋하지 않는다.
JWT_SECRET=

# ai-service (backend가 호출하는 base-url)
# 호스트 bootRun은 기본값 http://localhost:8000을 그대로 쓴다.
# 운영 compose는 내부 네트워크의 http://ai-service:8000으로 덮어쓴다.
PULSE_AI_BASE_URL=http://localhost:8000

# SMTP 메일 발송
# 로컬에서는 Gmail, 운영에서는 AWS SES 값을 주입한다.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
