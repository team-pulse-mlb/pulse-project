# 외부 API
BDL_API_KEY=
# ai-service가 OpenAI 호출에 사용한다(비우면 문구 생성만 실패, 앱 기동은 됨).
# Docker Compose가 저장소 루트의 .env에서 읽어 ai-service에 주입한다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# 이메일 인증 메일 발송용
MAIL_USERNAME=
MAIL_PASSWORD=

# S3 라이브 raw archive 리플레이
PULSE_REPLAY_S3_BUCKET=
PULSE_REPLAY_MAX_OBJECTS_PER_PREFIX=200
AWS_REGION=ap-northeast-2

# 회사망 프록시(Somansa 등) HTTPS 가로채기 대응(집망에서는 비워 둔다)
# 프록시 CA를 포함한 Java truststore 경로를 지정하면 수집·리플레이 스크립트가 JVM에 주입한다.
# 만드는 법은 backend/README.md의 "회사망 프록시(HTTPS 가로채기) 대응" 참고.
PULSE_JAVA_TRUSTSTORE=
PULSE_JAVA_TRUSTSTORE_PASSWORD=changeit

# 로컬 경기 시뮬레이션
# run-simulation.sh가 경기 ID를 자동으로 선택한다.
PULSE_SIMULATION_SPEED=20
PULSE_SIMULATION_PRESET=SURGE

# PostgreSQL
# 로컬 개발 비밀번호는 팀원마다 다르게 정해도 된다.
# 단, DBeaver와 Spring Boot도 같은 값을 사용해야 한다.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse

# Redis
# 로컬 개발 Redis는 비밀번호 없이 사용한다.
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
# RABBITMQ_PASSWORD가 비어 있으면 로컬 Compose 기동이 실패한다.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=pulse
RABBITMQ_PASSWORD=pulse

# 인증
# Git Bash에서 생성한 32바이트 Base64URL 값을 사용한다. 생성 방법은 README 참고.
JWT_SECRET=

# ai-service (backend가 호출하는 base-url)
# 호스트 bootRun은 기본값 http://localhost:8000을 그대로 쓴다.
# 운영 compose는 내부 네트워크의 http://ai-service:8000으로 덮어쓴다.
PULSE_AI_BASE_URL=http://localhost:8000
