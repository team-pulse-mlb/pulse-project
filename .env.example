# 외부 API
BDL_API_KEY=
OPENAI_API_KEY=

# S3 라이브 raw archive 리플레이
PULSE_REPLAY_S3_BUCKET=
PULSE_REPLAY_GAME_ID=
PULSE_REPLAY_DATE=
PULSE_REPLAY_MAX_OBJECTS_PER_PREFIX=200
AWS_REGION=ap-northeast-2
# PostgreSQL
# 로컬 개발 비밀번호는 팀원마다 다르게 정해도 된다.
# 단, DBeaver와 Spring Boot도 같은 값을 사용해야 한다.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse

# Redis
# 로컬 개발 Redis는 비밀번호 없이 사용한다.
REDIS_HOST=localhost
REDIS_PORT=6379

# 인증
JWT_SECRET=

# ai-service
AI_SERVICE_URL=http://localhost:8000
