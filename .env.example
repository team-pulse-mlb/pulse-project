# 외부 API
BDL_API_KEY=
OPENAI_API_KEY=

# S3 라이브 raw archive 리플레이
PULSE_REPLAY_S3_BUCKET=
PULSE_REPLAY_MAX_OBJECTS_PER_PREFIX=200
AWS_REGION=ap-northeast-2

# 로컬 경기 시뮬레이션
# run-simulation.sh가 경기 ID를 자동으로 선택한다.
PULSE_SIMULATION_SPEED=20
PULSE_SIMULATION_PRESET=SURGE

# PostgreSQL
# 로컬 개발 비밀번호는 팀원마다 다르게 정해도 된다.
# 단, DBeaver와 Spring Boot도 같은 값을 사용해야 한다.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse

# Redis
# 로컬 개발 Redis는 비밀번호 없이 사용한다.
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
# RABBITMQ_PASSWORD가 비어 있으면 로컬 Compose 기동이 실패한다.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=pulse
RABBITMQ_PASSWORD=pulse

# 인증
# 로컬에서는 32자 이상 임의 문자열이면 된다.
JWT_SECRET=

# ai-service
AI_SERVICE_URL=http://localhost:8000
