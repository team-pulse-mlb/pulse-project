{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadDeploymentAndBacktestObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::pulse-deploy-027903150609/deploy/*",
        "arn:aws:s3:::pulse-deploy-027903150609/backtest/pr/*"
      ]
    },
    {
      "Sid": "ListDeploymentAndBacktestPrefixes",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::pulse-deploy-027903150609",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["deploy/*", "backtest/pr/*"]
        }
      }
    },
    {
      "Sid": "WriteBacktestResults",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::pulse-deploy-027903150609/backtest/pr/*"
    },
    {
      "Sid": "EcrLogin",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "EcrPull",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer"
      ],
      "Resource": [
        "arn:aws:ecr:ap-northeast-2:027903150609:repository/pulse-backend",
        "arn:aws:ecr:ap-northeast-2:027903150609:repository/pulse-ai-service"
      ]
    },
    {
      "Sid": "ReadRuntimeSecrets",
      "Effect": "Allow",
      "Action": ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"],
      "Resource": [
        "arn:aws:secretsmanager:ap-northeast-2:027903150609:secret:pulse/prod/runtime-*",
        "arn:aws:secretsmanager:ap-northeast-2:027903150609:secret:rds!db-b48f4a6f-e24f-4634-b7f2-7d90f09afbd9-w3FsLQ",
        "arn:aws:secretsmanager:ap-northeast-2:027903150609:secret:pulse/backtest/readonly-*"
      ]
    }
  ]
}
